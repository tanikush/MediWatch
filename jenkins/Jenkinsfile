pipeline {
    agent any
    
    environment {
        DOCKER_REGISTRY = 'mediwatch'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Lint Python Code') {
            steps {
                script {
                    sh '''
                        pip3 install flake8 --break-system-packages
                        flake8 services/ --max-line-length=120 --extend-ignore=E302,E305,E501 --exclude=__pycache__,tests
                    '''
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                script {
                    sh '''
                        cd services/patient-service && pip3 install --break-system-packages || true && pytest tests/ -v || true
                        cd ../lab-service && pip3 install --break-system-packages || true && pytest tests/ -v || true
                        cd ../appointment-service && pip3 install --break-system-packages || true && pytest tests/ -v || true
                    '''
                }
            }
        }
        
        stage('Build Docker Images') {
            steps {
                script {
                    sh '''
                        docker build -t patient-service:${BUILD_NUMBER} services/patient-service/
                        docker build -t lab-service:${BUILD_NUMBER} services/lab-service/
                        docker build -t appointment-service:${BUILD_NUMBER} services/appointment-service/
                        
                        docker tag patient-service:${BUILD_NUMBER} patient-service:latest || true
                        docker tag lab-service:${BUILD_NUMBER} lab-service:latest || true
                        docker tag appointment-service:${BUILD_NUMBER} appointment-service:latest || true
                    '''
                }
            }
        }
        
        stage('Deploy Local') {
            steps {
                script {
                    sh '''
                        docker-compose -f /root/.jenkins/workspace/mediwatch-deploy/docker-compose.yml up -d
                        docker ps
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Check logs for details.'
        }
    }
}
